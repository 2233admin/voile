# Copy to .env and fill in values before running docker compose

# Path to your Obsidian vault on the host (mounted into the worker container)
OBSIDIAN_HOST_PATH=E:/knowledge

# Optional: override OneBot WebSocket endpoint (default: ws://lagrange:3001)
# Uncomment if you run NapCat/Lagrange outside docker
# ONEBOT_WS=ws://host.docker.internal:3001
